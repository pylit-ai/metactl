{
  "jsonrpc": "2.0",
  "id": "green-search-1",
  "method": "metactl.search",
  "params": {
    "query": "review flaky tests and style regressions",
    "config": {
      "api_version": "metactl/v2alpha1",
      "role": {
        "kind": "role",
