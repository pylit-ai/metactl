        "version": "1.0.0"
      },
      "packs": [
        {
          "kind": "pack",
          "id": "unit-test-loop",
          "version": "1.0.0"
        }
      ],
      "policy": {
        "kind": "policy",
        "id": "safe-review",
        "version": "1.0.0"
      },
      "targets": [
        {
          "kind": "target",
          "id": "claude-code",
          "version": "2026.03.25"
        }
      ],
      "defaults": {
        "brownfield_mode": "shadow_compile",
        "discovery_mode": "curated_only"
      },
      "metadata": {
        "owner": "magicwormhole-seed"
      }
    },
    "overlay": {
      "entrypoint": "magicwormhole_hotkey",
