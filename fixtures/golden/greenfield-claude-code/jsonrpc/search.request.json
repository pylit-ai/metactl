        "activation_class": "service",
        "side_effect_class": "network",
        "trust_tier": "external_unreviewed",
        "requires_confirmation": true,
        "task_tags": [
          "search",
          "scrape"
        ],
        "compatible_roles": [
          "reviewer"
        ],
        "compatible_targets": [
          "claude-code"
        ],
        "imports": [
          {
            "ecosystem": "skill_md",
            "origin": "https://example.com/dangerous-network-scraper",
            "digest": "sha256:0123456789abcdef0123456789abcdef"
          }
        ]
      }
