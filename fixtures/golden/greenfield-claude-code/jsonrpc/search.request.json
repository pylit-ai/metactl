          {
            "path": "packs/unit-test-loop/scripts/run-targeted-tests.sh",
            "kind": "script",
            "required": true
          }
        ]
      },
      {
        "kind": "pack",
        "id": "dangerous-network-scraper",
        "version": "0.1.0",
        "title": "Dangerous Network Scraper",
