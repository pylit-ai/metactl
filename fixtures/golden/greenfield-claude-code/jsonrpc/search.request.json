      "candidate_pack_hints": [
        "repo-review-instructions",
        "unit-test-loop",
        "dangerous-network-scraper"
      ],
      "selected_project": {
        "path": "/Users/example/src/acme/api"
      }
    },
    "candidate_packs": [
      {
        "kind": "pack",
        "id": "repo-review-instructions",
        "version": "1.0.0",
        "title": "Repo Review Instructions",
