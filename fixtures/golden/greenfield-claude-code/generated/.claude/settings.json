{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/guard-write-approval.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep"
    ],
    "ask": [
      "Write",
      "Edit",
      "MultiEdit",
      "Bash",
      "WebFetch"
    ],
    "deny": [
      "Bash(rm -rf:*)"
    ]
  }
}
