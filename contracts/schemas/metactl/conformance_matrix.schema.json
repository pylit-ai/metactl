{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "https://dropzone/contracts/schemas/metactl/conformance_matrix.schema.json",
  "title": "metactl v1 Conformance Matrix",
  "type": "object",
  "properties": {
    "api_version": {
      "const": "metactl/v2alpha1"
    },
    "kind": {
      "const": "conformance_matrix"
    },
    "id": {
      "$ref": "common.schema.json#/$defs/slug"
    },
    "version": {
      "$ref": "common.schema.json#/$defs/version_string"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "target_id": {
            "$ref": "common.schema.json#/$defs/slug"
          },
          "support_level": {
            "type": "string",
            "enum": [
              "conformant",
              "experimental",
              "degraded"
            ]
          },
          "required_outputs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "apply_modes": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "copy",
                "patch",
                "symlink",
                "takeover"
              ]
            },
            "uniqueItems": true
          },
          "gates": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "notes": {
            "type": "string",
            "maxLength": 2000
          }
        },
        "required": [
          "target_id",
          "support_level",
          "required_outputs",
          "gates"
        ],
        "patternProperties": {
          "^x-": {}
        },
        "additionalProperties": false
      },
      "uniqueItems": true
    },
    "release_gates": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "required": [
    "api_version",
    "kind",
    "id",
    "version",
    "title",
    "targets",
    "release_gates"
  ],
  "patternProperties": {
    "^x-": {}
  },
  "additionalProperties": false
}
