{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "https://dropzone/contracts/schemas/metactl/jsonrpc/common_jsonrpc.schema.json",
  "title": "JSON-RPC 2.0 Envelope Fragments",
  "$defs": {
    "id": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ]
    },
    "request_base": {
      "type": "object",
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "id": {
          "$ref": "#/$defs/id"
        },
        "method": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "params": {
          "type": "object"
        }
      },
      "required": [
        "jsonrpc",
        "id",
        "method",
        "params"
      ],
      "additionalProperties": false
    },
    "response_base": {
      "type": "object",
      "properties": {
        "jsonrpc": {
          "const": "2.0"
        },
        "id": {
          "$ref": "#/$defs/id"
        }
      },
      "required": [
        "jsonrpc",
        "id"
      ],
      "additionalProperties": true
    },
    "error": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 2000
        },
        "data": {
          "type": "object"
        }
      },
      "required": [
        "code",
        "message"
      ],
      "additionalProperties": true
    }
  }
}
