{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "$id": "https://dropzone/contracts/schemas/metactl/skill_relation.schema.json",
  "title": "metactl Skill Relation",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "kind": {
        "type": "string",
        "enum": [
          "same_name_as",
          "same_source_as",
          "duplicate_candidate",
          "supersedes_candidate",
          "conflicts_with_candidate",
          "complements_candidate",
          "visibility_ambiguous_with",
          "generated_from_pack"
        ]
      },
      "left_id": { "type": "string" },
      "right_id": { "type": "string" },
      "confidence": {
        "type": "string",
        "enum": ["high", "medium", "low"]
      },
      "reason_code": { "type": "string" },
      "evidence": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "required": ["kind", "left_id", "right_id", "confidence", "reason_code", "evidence"]
  }
}
